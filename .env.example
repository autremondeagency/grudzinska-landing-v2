# Copy to .env.local for local dev, or set in Vercel Project Settings → Environment Variables.

# Supabase (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Resend (https://resend.com — free 100/day, 3000/month)
RESEND_API_KEY=re_...
NOTIFY_EMAIL=dietetyk.grudzinska@gmail.com

# Admin panel (any strong password — used as Basic Auth)
ADMIN_PASSWORD=set_a_strong_password_here

# Meta Lead Ads webhook (set after creating Meta App + Page Access Token)
META_WEBHOOK_VERIFY_TOKEN=any_random_string_min_20_chars
META_PAGE_ACCESS_TOKEN=EAA...long...token

# Public — exposed to client. Leave blank until Pixel is created in Meta Events Manager.
VITE_META_PIXEL_ID=
